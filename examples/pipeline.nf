#!/usr/bin/env nextflow
// Auto-generated by BioPilot from a validated, schema-checked plan.
// Each process is pinned to a BioContainers image for reproducibility.
nextflow.enable.dsl=2


// Original request: find variants in these reads against the reference genome

process P_BWA_INDEX {
    container 'quay.io/biocontainers/bwa:0.7.19'
    tag 'bwa_index'

    script:
    """
    bwa index data/test/ref.fasta
    """
}

process P_FAIDX {
    container 'quay.io/biocontainers/samtools:1.23.1'
    tag 'faidx'

    script:
    """
    samtools faidx data/test/ref.fasta
    """
}

